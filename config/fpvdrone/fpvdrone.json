{
  // ═══════════════════════════════════════════════════════
  // FPV Drone — General Config
  // ═══════════════════════════════════════════════════════
  // Отредактируйте значения и перезапустите игру для применения.
  // Работает как на клиенте, так и на выделенном сервере.
  // Значения сервера переопределяют настройки клиентов для всех игроков.

  // ── Простой режим ──

  // Быстрая настройка дальности. Укажите желаемую макс. дальность в блоках,
  // и ВСЕ параметры дистанции ниже автоматически смасштабируются.
  // Установите 0 для отключения автонастройки и ручной конфигурации.
  // Range: 0 (off) or 50 — 10000
  "simpleRange": 0,

  // ── Сигнал / Дистанция ──
  // (Когда параметр simpleRange > 0, значения дистанции масштабируются автоматически,
  // а ручные значения ниже игнорируются.)

  // Максимальная дальность полёта в блоках. За этой дистанцией
  // сигнал падает до нуля, и дрон активирует фейлсейв.
  // Range: 50 — 10000
  "maxRange": 350,

  // Дистанция (в блоках), на которой видеопоток начинает заикаться.
  // Ближе этого расстояния картинка идеально чистая.
  // Range: 0 — 10000
  "freezeStartDistance": 100,

  // Штраф сигнала за препятствия между пилотом и дроном.
  // 0.0 = препятствия не влияют. 1.0 = по умолчанию. 2.0 = в два раза сильнее.
  // Range: 0.0 — 10.0
  "obstaclePenaltyMultiplier": 1.0,

  // Макс. штраф сигнала (в %), когда дрон летит низко над землёй
  // на большой дистанции. Симулирует затухание радиоволн у земли. 0 = отключено.
  // Range: 0.0 — 100.0
  "groundProximityPenaltyMax": 35.0,

  // Дистанция (в блоках), на которой начинает действовать штраф за близость к земле.
  // Ближе этого порога = штрафа нет.
  // Range: 0 — 10000
  "groundProximityDistanceStart": 30,

  // Высота над землёй (в блоках), ниже которой дрон считается
  // низколетящим для применения штрафа близости к земле.
  // Range: 1 — 256
  "groundProximityHeightThreshold": 15,

  // Бонус сигнала на каждый блок высоты над базовой линией.
  // Выше высота = лучше сигнал. 0 = без бонуса.
  // Range: 0.0 — 10.0
  "heightBonusPerBlock": 0.1,

  // Высота (координата Y), выше которой начинает применяться бонус за высоту.
  // Полёт ниже этой отметки не даёт бонуса.
  // Range: -64 — 320
  "heightBaseline": 64,

  // Скорость реагирования уровня сигнала на изменения.
  // Низкие значения = плавные кинематографичные переходы. Высокие = мгновенно.
  // Range: 0.01 — 1.0
  "signalSmoothing": 0.15,

  // Количество последовательных кадров с нулевым сигналом до срабатывания
  // фейлсейва. Выше = больше терпимость к кратковременным потерям связи.
  // Range: 1 — 600
  "zeroSignalFramesForDisconnect": 30,

  // ── Зависание видео ──

  // Насколько агрессивно заикается видео при ухудшении сигнала.
  // Выше = больше застывших кадров на расстоянии. 0 = без зависаний.
  // Range: 0.0 — 50.0
  "freezeIntensity": 5.0,

  // ── Фейлсейв (Failsafe) ──

  // Скорость снижения (блоков за такт) при потере сигнала.
  // Дрон медленно опускается, пока не приземлится или не вернёт связь.
  // Range: 0.0 — 10.0
  "failsafeDescentRate": 0.5,

  // Множитель горизонтальной скорости за такт при потере связи.
  // 1.0 = без торможения. 0.0 = мгновенная остановка по горизонтали.
  // Range: 0.0 — 1.0
  "failsafeHorizontalDamping": 0.95,

  // ── Взрыв ──

  // Сила разрушения блоков взрывом. 0.0 = блоки не ломаются.
  // 1.0 = эквивалентно динамиту (TNT). 2.0 = двойная сила.
  // Range: 0.0 — 2.0
  "explosionBlockPower": 0.0,

  // Радиус взрывной волны (в блоках) для нанесения урона.
  // Range: 1.0 — 32.0
  "explosionBlastRadius": 10.0,

  // Пиковый урон взрывной волны на границе зоны поражения.
  // Range: 0.0 — 200.0
  "explosionBlastDamage": 40.0,

  // Радиус мгновенной смерти (в блоках). Существа внутри этого радиуса
  // погибают независимо от брони или расстояния.
  // Range: 0.0 — 16.0
  "explosionKillZone": 2.0,

  // Если включено, взрывная волна открывает все двери, люки
  // и заборы в радиусе взрыва.
  "explosionOpensDoors": true,

  // Сила взрыва при таране камикадзе или детонации RPG-дрона.
  // Влияет на радиус разлёта осколков и урон.
  // Range: 1.0 — 10.0
  "kamikazeExplosionPower": 4.0,

  // Количество осколочных лучей при взрыве.
  // Больше лучей = лучше регистрация попаданий за укрытиями, но выше нагрузка на процессор.
  // Range: 8 — 512
  "shrapnelCount": 128,

  // ── Урон ──

  // Если включено, дрон наносит урон при столкновении
  // с существами (мобами и игроками).
  "droneCollisionDamage": true,

  // ── Дистанция видимости наблюдателя ──

  // Дистанция отслеживания сущности дрона (в блоках). Управляет тем, как далеко
  // наблюдатели могут видеть полёт дрона и его анимации.
  // Только на стороне сервера — на клиенты не синхронизируется.
  // Range: 64 — 2048
  "droneObserverRange": 500,

  // ── Client Settings (camera, input, video — ignored on dedicated servers) ──

  // Camera tilt angle in degrees
  "defaultAngle": 25.0,

  // Field of view in degrees
  "fov": 120.0,

  // Force keyboard+mouse input, ignore connected controller
  "forceKbm": false,

  // Show stick position overlay during flight
  "stickOverlay": false,

  // Video resolution scale: RES_10, RES_15, RES_20, RES_25, RES_33, RES_50
  "videoResolution": "RES_25"
}
